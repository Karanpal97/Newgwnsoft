# Copy this to .env and fill in your values

# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@your-neon-host/dbname?sslmode=require

# CloudAMQP RabbitMQ connection string (get from cloudamqp.com free tier)
RABBITMQ_URL=amqps://user:password@your-cloudamqp-host/vhost

# Directory where users.csv, transactions.csv, and result.csv are stored
# On Render, use /opt/render/project/src/data or a persistent disk mount
DATA_DIR=./data
