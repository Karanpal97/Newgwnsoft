# Next.js / Node (frontend/)
# ───────────────────────────────────────────
frontend/node_modules/
node_modules/

# Next.js build output
frontend/.next/
.next/

# Production build
frontend/out/
out/

# Next.js cache
frontend/.turbo/
.turbo/

# Env files (add your own values, don't commit)
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local

