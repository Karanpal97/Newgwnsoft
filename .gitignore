backend/.env
.env
*.env

# Database files (SQLite for local dev)
backend/jobs.db
backend/celery_results.db
*.db
*.sqlite3

# Generated data files (too large for git — ~1 GB)
backend/data/
data/
*.csv

# Celery
celerybeat-schedule
celerybeat.pid

